meta {
  name: Match Score Subscription
  type: graphql
  seq: 3
}

post {
  url: {{wsUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:graphql {
  subscription MatchScoreUpdated($matchId: String!) {
    matchScoreUpdated(matchId: $matchId) {
      matchId
      score
      status
      winnerId
      updatedAt
    }
  }
}

body:graphql:vars {
  {
    "matchId": "MATCH_ID_HERE"
  }
}
