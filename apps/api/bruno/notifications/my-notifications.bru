meta {
  name: My Notifications
  type: graphql
  seq: 1
}

post {
  url: {{baseUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:graphql {
  query MyNotifications($unreadOnly: Boolean) {
    myNotifications(unreadOnly: $unreadOnly) {
      id
      userId
      type
      title
      body
      payload
      read
      createdAt
    }
  }
}

body:graphql:vars {
  {
    "unreadOnly": false
  }
}
