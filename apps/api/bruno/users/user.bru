meta {
  name: Get User by ID
  type: graphql
  seq: 3
}

post {
  url: {{baseUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:graphql {
  query GetUser($id: String!) {
    user(id: $id) {
      id
      email
      firstName
      lastName
      role
      avatar
      locale
      createdAt
    }
  }
}

body:graphql:vars {
  {
    "id": "replace-with-user-id"
  }
}
