meta {
  name: Admin User
  type: graphql
  seq: 3
}

post {
  url: {{baseUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:graphql {
  query AdminUser($userId: String!) {
    adminUser(userId: $userId) {
      id
      email
      firstName
      lastName
      role
      avatar
      createdAt
      updatedAt
    }
  }
}

body:graphql:vars {
  {
    "userId": "USER_ID_HERE"
  }
}
