meta {
  name: Delete Competition
  type: graphql
  seq: 9
}

post {
  url: {{baseUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:graphql {
  mutation DeleteCompetition($id: String!) {
    deleteCompetition(id: $id) {
      id
      name
      status
    }
  }
}

body:graphql:vars {
  {
    "id": "COMPETITION_ID_HERE"
  }
}
