meta {
  name: Login
  type: graphql
  seq: 2
}

post {
  url: {{baseUrl}}
  body: graphql
  auth: none
}

body:graphql {
  mutation Login($input: LoginInput!) {
    login(input: $input) {
      accessToken
      refreshToken
      user {
        id
        email
        role
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "email": "athlete@example.com",
      "password": "password123"
    }
  }
}
